# ==============================================================================
# 1. CORE SERVER & ENVIRONMENT CONFIGURATION
# ==============================================================================
ENV=development
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key
JWT_ISSUER=SmartWardrobeServer
JWT_AUDIENCE=SmartWardrobeClient
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_FORGOT_PASSWORD_EXPIRATION_MINUTES=15

# Request Timeout & Rate Limiting
REQUEST_TIMEOUT_SECONDS=300
RATE_LIMIT_TOKEN_LIMIT=100
RATE_LIMIT_TOKENS_PER_PERIOD=20
RATE_LIMIT_REPLENISHMENT_SECONDS=10
AI_RPM_LIMIT=5

# Startup Connection Retry
STARTUP_RETRY_ATTEMPT_1_SECONDS=5
STARTUP_RETRY_ATTEMPT_2_SECONDS=15
STARTUP_RETRY_ATTEMPT_3_SECONDS=30

# Wardrobe Processing Recovery
WARDROBE_RETRY_DELAY_1_SECONDS=60
WARDROBE_RETRY_DELAY_2_SECONDS=300
WARDROBE_RETRY_DELAY_3_SECONDS=900
WARDROBE_PROCESSING_STALE_MINUTES=20
WARDROBE_PROCESSING_MAX_RETRIES=3
WARDROBE_RECOVERY_SCAN_CRON=0 */5 * * * *
WARDROBE_CATEGORY_CACHE_TTL_SECONDS=300

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_TO_FILE=false

# OTP Configuration
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5
OTP_RESEND_INTERVAL_SECONDS=60

# ==============================================================================
# 2. DATABASE, CACHE & INFRASTRUCTURE CONFIGURATION
# ==============================================================================
# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=smart_wardrobe_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Message Broker
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=123456

# Elasticsearch Search Engine
ELASTICSEARCH_ADDRESS=http://localhost:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# ==============================================================================
# 3. THIRD-PARTY APIS & SERVICES INTEGRATION
# ==============================================================================
# Google SMTP Email Service
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SENDER_NAME="SmartWardrobe Support"
EMAIL_SENDER_EMAIL=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Ngrok Webhook Tunneling (Local Dev webhook testing)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your_custom_static_domain_here
NGROK_TARGET=backend:8080

# PayOS Payment Gateway
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here
PAYOS_RETURN_URL=http://localhost:3000
PAYOS_CANCEL_URL=http://localhost:3000

# Cloudinary Media Storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=
CLOUDINARY_ITEM_FOLDER=
CLOUDINARY_OUTFIT_FOLDER=
CLOUDINARY_POST_FOLDER=

# ==============================================================================
# 4. AI MODEL PROVIDERS CONFIGURATION
# ==============================================================================
# AI Stage 1: Multimodal Vision API (Item analysis / classification)
VISION_PRIMARY_PROVIDER=
VISION_PRIMARY_API_KEY=
VISION_PRIMARY_ENDPOINT=
VISION_PRIMARY_MODEL=
VISION_FALLBACK_PROVIDER=
VISION_FALLBACK_API_KEY=
VISION_FALLBACK_ENDPOINT=
VISION_FALLBACK_MODEL=

# AI Stage 2: Text Embedding API (Semantic Vector Search)
EMBEDDING_PRIMARY_PROVIDER=
EMBEDDING_PRIMARY_API_KEY=
EMBEDDING_PRIMARY_ENDPOINT=
EMBEDDING_PRIMARY_MODEL=
EMBEDDING_FALLBACK_PROVIDER=
EMBEDDING_FALLBACK_API_KEY=
EMBEDDING_FALLBACK_ENDPOINT=
EMBEDDING_FALLBACK_MODEL=

# AI Stage 3: Text Generation API (Stylist Chat & Recommendations)
TEXT_PRIMARY_PROVIDER=
TEXT_PRIMARY_API_KEY=
TEXT_PRIMARY_ENDPOINT=
TEXT_PRIMARY_MODEL=
TEXT_FALLBACK_PROVIDER=
TEXT_FALLBACK_API_KEY=
TEXT_FALLBACK_ENDPOINT=
TEXT_FALLBACK_MODEL=

# ==============================================================================
# 5. BUSINESS LOGIC & TUNING HYPERPARAMETERS
# ==============================================================================
# Default Quota Limits (Free tier user fallbacks)
QUOTA_DEFAULT_WARDROBE_LIMIT=100
QUOTA_DEFAULT_AI_OUTFIT_LIMIT=3
QUOTA_DEFAULT_AI_CHAT_LIMIT=3

# Advanced RAG Pipeline Configuration (Stylist Recommendation Candidate Filtering)
RAG_RECENTLY_WORN_PENALTY_DAYS=3
RAG_LONG_UNWORN_BONUS_DAYS=14
RAG_RRF_K_PARAMETER=30

# Community Features
COMMUNITY_MAX_PERSONALIZED_WINDOW=100
