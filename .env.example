# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=your_password
DB_NAME=smart_wardrobe_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Ho_Chi_Minh

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=123456

# Elasticsearch Configuration
ELASTICSEARCH_ADDRESS=http://localhost:9200
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# Server Configuration
ENV=development
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key
JWT_ISSUER=SmartWardrobeServer
JWT_AUDIENCE=SmartWardrobeClient
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=30
JWT_FORGOT_PASSWORD_EXPIRATION_MINUTES=15

# Timeout & Rate Limiting
REQUEST_TIMEOUT_SECONDS=300
RATE_LIMIT_TOKEN_LIMIT=100
RATE_LIMIT_TOKENS_PER_PERIOD=20
RATE_LIMIT_REPLENISHMENT_SECONDS=10
AI_RPM_LIMIT=5

# Logging Configuration
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
LOG_TO_FILE=false

# OTP Configuration
OTP_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5
OTP_RESEND_INTERVAL_SECONDS=60

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SENDER_NAME="SmartWardrobe Support"
EMAIL_SENDER_EMAIL=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# Default Quota Limits (Free User default fallback limits)
QUOTA_DEFAULT_WARDROBE_LIMIT=30
QUOTA_DEFAULT_AI_OUTFIT_LIMIT=3
QUOTA_DEFAULT_AI_CHAT_LIMIT=3

# Ngrok Local Webhook Tunneling Configuration
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your_custom_static_domain_here

# Ngrok traffic forwarding target address
# Full docker compose mode execution
NGROK_TARGET=backend:8080
# Hybrid development mode execution with host backend debugging
# NGROK_TARGET=host.docker.internal:8080

# PayOS Payment Gateway Configuration
PAYOS_CLIENT_ID=your_payos_client_id_here
PAYOS_API_KEY=your_payos_api_key_here
PAYOS_CHECKSUM_KEY=your_payos_checksum_key_here
PAYOS_RETURN_URL=http://localhost:3000
PAYOS_CANCEL_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_AVATAR_FOLDER=
CLOUDINARY_ITEM_FOLDER=
CLOUDINARY_OUTFIT_FOLDER=
CLOUDINARY_POST_FOLDER=

# AI STAGE 1: MULTIMODAL VISION CONFIGURATION
VISION_PRIMARY_PROVIDER=
VISION_PRIMARY_API_KEY=
VISION_PRIMARY_ENDPOINT=
VISION_PRIMARY_MODEL=

VISION_FALLBACK_PROVIDER=
VISION_FALLBACK_API_KEY=
VISION_FALLBACK_ENDPOINT=
VISION_FALLBACK_MODEL=

# AI STAGE 2: TEXT EMBEDDING CONFIGURATION
EMBEDDING_PRIMARY_PROVIDER=
EMBEDDING_PRIMARY_API_KEY=
EMBEDDING_PRIMARY_ENDPOINT=
EMBEDDING_PRIMARY_MODEL=

EMBEDDING_FALLBACK_PROVIDER=
EMBEDDING_FALLBACK_API_KEY=
EMBEDDING_FALLBACK_ENDPOINT=
EMBEDDING_FALLBACK_MODEL=

# AI STAGE 3: TEXT GENERATION CONFIGURATION (Stylist Chat & Recommendations)
TEXT_PRIMARY_PROVIDER=
TEXT_PRIMARY_API_KEY=
TEXT_PRIMARY_ENDPOINT=
TEXT_PRIMARY_MODEL=

TEXT_FALLBACK_PROVIDER=
TEXT_FALLBACK_API_KEY=
TEXT_FALLBACK_ENDPOINT=
TEXT_FALLBACK_MODEL=
